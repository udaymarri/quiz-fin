# Frontend Environment Variables (Vite)

# The base URL of your Python backend API
VITE_API_URL="https://your-backend-url.railway.app"

# Optional: The base URL for the WebSocket connection (defaults to mapping VITE_API_URL to ws/wss)
VITE_WS_URL="wss://your-backend-url.railway.app"

# Firebase Client SDK Configuration (currently remains in services/firebase.ts for historical reasons, 
# but you can move them here if you want to further secure them)
# VITE_FIREBASE_API_KEY="..."
# VITE_FIREBASE_AUTH_DOMAIN="..."
# VITE_FIREBASE_PROJECT_ID="..."
