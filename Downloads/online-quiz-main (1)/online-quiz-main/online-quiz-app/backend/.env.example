# Backend Environment Variables
# These should be set in your deployment platform (Railway/Render) and .env file for local development

# Firebase Admin SDK credentials (JSON string)
# Get this from Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON='{"type": "service_account", "project_id": "...", "private_key_id": "...", "private_key": "...", "client_email": "...", "client_id": "...", "auth_uri": "...", "token_uri": "...", "auth_provider_x509_cert_url": "...", "client_x509_cert_url": "...", "universe_domain": "googleapis.com"}'

# Gemini AI API Key
# Get this from https://aistudio.google.com/
GEMINI_API_KEY="your-gemini-api-key-here"

# Optional: Path to a service account JSON file (alternative to FIREBASE_SERVICE_ACCOUNT_JSON)
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Port for the backend server (default 8000)
PORT=8000
